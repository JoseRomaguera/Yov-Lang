
Main :: func
{
    // Multiple expressions
    Assert(5 == 5 && 10 + 10 == 20);
    Assert(5 * 5 == +25 && (5 + 12) / 2 == 8);
    Assert(false || (2 % 1 != 1 && "Test" == "Test"));
    Assert("Hello".size == -((+2+3) * -1));
    Assert(StrSplit(PathResolve("f0" / "f1" + "\\test\\foo.x"), "/").count == 4);
    Assert("Yov".size == "Sex".size);
    
    
    // Tuples
    {
        v0, v1 := FnReturnTwo();
        Assert(v0 == 12 && v1 == 32);
        
        v2 := FnReturnTwo();
        Assert(v2 == 12);
        
        v3, v4 := 5;
        Assert(v3 == 5 && v4 == 5);
        
        v5, v6 := FnReturnOne();
        Assert(v5 == 69 && v6 == 69);
        
        v7, v8 : Int = FnReturnTwo();
        Assert(v7 == 12 && v8 == 32);
        
        v9 : Int = FnReturnTwo();
        Assert(v9 == 12);
        
        v10, v11 : Int = 5;
        Assert(v10 == 5 && v11 == 5);
        
        v12, v13 := FnReturnTwo() * 2;
        Assert(v12 == 24 && v13 == 24);
        
        v14, v15 := -FnReturnTwo();
        Assert(v14 == -12 && v15 == -12);
        
        a, b: Int;
        
        a, b = FnReturnTwo();
        Assert(a == 12 && b == 32);
        
        a = FnReturnTwo();
        Assert(a == 12);
        
        a, b = 5;
        Assert(a == 5 && b == 5);
        
        a, b = FnReturnOne();
        Assert(a == 69 && b == 69);
        
        a, b = FnReturnTwo() * 2;
        Assert(a == 24 && b == 24);
        
        a, b = -FnReturnTwo();
        Assert(a == -12 && b == -12);
    }
}

FnReturnOne :: func -> Int {
    return 69;
}

FnReturnTwo :: func -> (r0: Int, r1: Int) {
    r0 = 12;
    r1 = 32;
}