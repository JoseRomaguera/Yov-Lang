
Foo :: struct {
    ref: Int&;
    val: Int;
    child: Foo&;
}

global_val : Int;
global_ref : Int&;

Main :: func
{
    global_val = 0;
    global_ref = &global_val;
    
    val0 := 4;
    ref0 := &val0;
    
    Assert(val0 == ref0);
    val0 = 5;
    Assert(val0 == ref0);
    ref0 = 6;
    Assert(val0 == ref0);
    
    
    ref0 = global_ref;
    Assert(val0 != ref0);
    
    ref0 = 7;
    Assert(ref0 == global_ref && ref0 == global_val);
    
    foo0: Foo;
    foo0.ref = &val0;
    foo0.val = ref0;
    foo0.child = &foo0;
    
    Assert(foo0.ref == val0);
    Assert(foo0.val == 7 && foo0.val == foo0.child.val);
    
    foo1: Foo;
    foo1.child = &foo0;
    
    Assert(foo0.val == foo1.child.val && foo1.val != foo1.child.val);
    
    {
        x := 5;
        inc(&x);
        Assert(x == 6);
    }
    
    {
        a := 5;
        b := &a;
        c := &b;
        
        c = 10;
        
        Assert(a == 10);
    }
}

inc :: func (v:Int&) {
    v += 1;
}