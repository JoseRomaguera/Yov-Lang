
En0 :: enum {
    A, B = 2, C
}

Main :: func
{
    // Definitions
    {
        int0 : Int;
        int1 : Int = 10;
        int2 : Int = int0 + int1;
        int3 := 13;
        int4 := int2;
        int0 += int1;
        int0 -= int3;
        int0 *= 2;
        int0 /= 1;
        int1 = int2 % 2;
        int3 %= 2;
        int3 = -int3 - 1;
        
        PrintLn("{int0}, {int1}, {int2}, {int3}, {int4}");
        Assert(int0 == -6 && int1 == 0 && int2 == 10 && int3 == -2 && int4 == 10);
    }
    
    // Strings
    {
        str0: String;
        str0 += "ello";
        str0 += " " + "World";
        
        codepoint : UInt = '!';
        str0 += codepoint;
        
        codepoint = 'H';
        str0 = codepoint + str0;
        
        Assert(str0 == "Hello World!");
        
        path0 := "foo0/foo1/foo2" / "../foo.txt";
        Assert(path0 == "foo0/foo1/foo.txt");
        
        inter0 := "str0.size = {str0.size}";
        inter1 := "str0 is empty = {str0.size == 0}";
        Assert(inter0 == "str0.size = 12");
        Assert(inter1 == "str0 is empty = false");
    }
    
    // Enums
    {
        v0 := En0.B;
        v1 := En0.A;
        v2 := En0.C;
        
        Assert(v0.value == 2 && v0.name == "B");
        Assert(v1.value == 0 && v1.name == "A");
        Assert(v2.value == 2 && v2.name == "C");
        Assert(v1 != v2);
        Assert(En0.B != En0.C);
        Assert(En0.B.value == En0.C.value);
    }
    
    // Array iteration mutation
    {
        arr := [1,2,3];
        
        for (v,i: arr) {
            arr[i] *= 2;
        }
        
        Assert(arr[2] == 6);
    }
    
    // Intrinsics
    
    path := Env("PATH");
    paths := StrSplit(path, ";");
    
    for (p: paths) {
        p = PathResolve(p);
    }
}